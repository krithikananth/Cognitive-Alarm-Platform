# ──────────────────────────────────────────────────────────
# Intelligent Cognitive Alarm Platform — Environment Config
# ──────────────────────────────────────────────────────────

# Project
PROJECT_NAME=Intelligent Cognitive Alarm Platform
VERSION=1.0.0

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite (development)
DATABASE_URL=sqlite:///./icap.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://icap_user:icap_password@localhost:5432/icap_db

# Redis (recommendation cache — optional; app falls back to live compute if down)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=0.5
RECOMMENDATION_CACHE_TTL_SECONDS=300

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:5173"]

# Frontend SPA (OAuth + password-reset / email-verification links)
FRONTEND_URL=http://localhost:3000

# Auth token lifetimes (password reset / email verification)
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# SMTP (optional — when unset, reset/verify links are logged instead of emailed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Intelligent Cognitive Alarm
SMTP_USE_TLS=true

# OAuth2 — Google
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match OAUTH2_GOOGLE_REDIRECT_URI exactly.
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
